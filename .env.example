# Environment Variables Example
# Copy this to .env (or .env.sit) and fill in your real values.
# IMPORTANT: .env holds real credentials — it is git-ignored, never commit it.

# ============================================
# Customer API (api-sit.askmebill.com)
# ============================================
API_BASE_URL=https://api-sit.askmebill.com

# User A - for general rate limit tests (REQUIRED)
AUTH_EMAIL=your-username
AUTH_PASSWORD=your-password
AUTH_2FA=your-totp-code            # TOTP code for is_accessapi=true

# User B - for TC-05 User Isolation tests (use a real, distinct account)
AUTH_EMAIL_B=your-second-username
AUTH_PASSWORD_B=your-password

# Additional Users C-L (for TC-06 parallel testing)
AUTH_EMAIL_C=user-c
AUTH_PASSWORD_C=your-password

AUTH_EMAIL_D=user-d
AUTH_PASSWORD_D=your-password

AUTH_EMAIL_E=user-e
AUTH_PASSWORD_E=your-password

AUTH_EMAIL_F=user-f
AUTH_PASSWORD_F=your-password

AUTH_EMAIL_G=user-g
AUTH_PASSWORD_G=your-password

AUTH_EMAIL_H=user-h
AUTH_PASSWORD_H=your-password

AUTH_EMAIL_I=user-i
AUTH_PASSWORD_I=your-password

AUTH_EMAIL_J=user-j
AUTH_PASSWORD_J=your-password

AUTH_EMAIL_K=user-k
AUTH_PASSWORD_K=your-password

AUTH_EMAIL_L=user-l
AUTH_PASSWORD_L=your-password

# ============================================
# BO API (apixint-sit.askmebill.com) - for TC-08 admin-exempt
# ============================================
BO_API_BASE_URL=https://apixint-sit.askmebill.com
BO_EMAIL=your-superadmin-username
BO_PASSWORD=your-password
BO_2FA=your-totp-code

# Optional: customer account used in TC-08 comparison
# CUSTOMER_EMAIL=your-customer-username
# CUSTOMER_PASSWORD=your-password
